# ── Domain ────────────────────────────────────────────────────────────────────
# The subdomain you'll point at this droplet (e.g. n8n.akcc.org.au).
# DNS: add an A record → droplet public IP before running compose up.
N8N_DOMAIN=n8n.yourdomain.com

# ── Postgres ──────────────────────────────────────────────────────────────────
# Strong random password for the local Postgres instance.
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── n8n editor basic-auth ─────────────────────────────────────────────────────
# Lock the n8n editor behind a username + password.
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── n8n encryption key ────────────────────────────────────────────────────────
# Protects stored credentials inside n8n. Set ONCE and never change.
# Generate: openssl rand -hex 32
N8N_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_STRING

# ── Webhook signing secret ────────────────────────────────────────────────────
# Shared secret used by the AKCC Next.js app to HMAC-sign webhook payloads
# (Day 7). n8n workflows verify this header before processing.
# Generate: openssl rand -hex 32
# Add the same value to Vercel env vars as N8N_WEBHOOK_SECRET.
N8N_WEBHOOK_SECRET=CHANGE_ME_STRONG_SECRET

# ── Resend (used by n8n workflows to send transactional emails) ───────────────
# Same API key as used by the Next.js app — add here so n8n workflows can
# call the Resend API directly via HTTP Request nodes.
RESEND_API_KEY=re_...
N8N_FROM_EMAIL=AKCC <no-reply@yourdomain.com>

# ── Admin email (for workflow notifications) ──────────────────────────────────
ADMIN_EMAIL=your-admin@email.com
