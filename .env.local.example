# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Supabase — get these from your Supabase project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # SERVER ONLY — never NEXT_PUBLIC_

# Stripe — get these from dashboard.stripe.com > Developers > API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...                           # SERVER ONLY
STRIPE_WEBHOOK_SECRET=whsec_...                         # SERVER ONLY

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Trigger.dev — get from cloud.trigger.dev → project settings → API keys
TRIGGER_SECRET_KEY=tr_dev_...          # SERVER ONLY — never NEXT_PUBLIC_
TRIGGER_PROJECT_REF=proj_...           # non-secret; also set in trigger.config.ts

# Resend — get from resend.com → API Keys
RESEND_API_KEY=re_...                  # SERVER ONLY
RESEND_FROM_EMAIL=AKCC <no-reply@yourdomain.com>  # must be a verified Resend domain
ADMIN_EMAIL=your-admin@email.com       # receives prayer notifications + other admin alerts

# n8n webhook — get webhook URL from your n8n instance (deploy/n8n/README.md)
# Leave blank in dev if n8n is not running; emitToN8n() will skip gracefully.
N8N_WEBHOOK_URL=https://n8n.yourdomain.com/webhook/akcc   # SERVER ONLY
N8N_WEBHOOK_SECRET=same-value-as-in-deploy/n8n/.env       # SERVER ONLY — must match n8n .env
